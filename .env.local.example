# ============================================================
# LOCAL DEV PROFILE — connects to Cloud SQL + Upstash Redis
# ============================================================
# Copy this to .env.local and fill in real values.
# .env.local is gitignored and overrides .env for `npm run dev`.
#
# Prerequisites:
#   1. Cloud SQL Auth Proxy running (see scripts/start-proxy.ps1)
#   2. Upstash Redis account — https://upstash.com (free tier)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LittleSparks (Dev)

# Auth — use any 32+ char random string for local dev
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-secret-change-me-32chars!!

# Database — Cloud SQL Auth Proxy listens on localhost:5433
# (port 5433 avoids conflict with any local postgres on 5432)
# DB is "littlesparks_dev" — separate from production "littlesparks"
DATABASE_URL=postgresql://postgres:CLOUD_SQL_POSTGRES_PASSWORD@localhost:5433/littlesparks_dev

# Redis — Upstash serverless Redis (free tier at https://upstash.com)
# Copy the "REDIS_URL" from your Upstash console (rediss://... format)
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_ENDPOINT:6380

# Email — leave as placeholder, emails won't send in dev
RESEND_API_KEY=re_placeholder_local_dev
EMAIL_FROM=hello@littlesparks.dev

# Storage — leave as placeholder unless testing uploads
S3_BUCKET=littlesparks-assets
S3_REGION=auto
S3_ACCESS_KEY_ID=placeholder
S3_SECRET_ACCESS_KEY=placeholder
S3_ENDPOINT=https://placeholder.r2.cloudflarestorage.com

# GCP
GCP_PROJECT_ID=project-0ddfb2d3-8c78-4896-9a8
GCP_REGION=asia-south1

# Feature Flags
NEXT_PUBLIC_ENABLE_LEADERBOARD=true
NEXT_PUBLIC_ENABLE_PARENT_PORTAL=true
